# ─────────────────────────────────────────────────────────────
# 개발 편의용 환경변수 예시 (CRA: REACT_APP_* 접두사만 주입됨)
#
# 사용법: 이 파일을 복사해 `.env.development.local` 로 만들고 값을 채우세요.
#   (`.env.development.local` 은 .gitignore 처리되어 커밋되지 않습니다)
#
# 모든 설정은 NODE_ENV=development (npm start) 일 때만 동작하며,
# 프로덕션 빌드(npm run build)에는 영향을 주지 않습니다.
# 변경 후에는 개발 서버를 재시작해야 적용됩니다.
# ─────────────────────────────────────────────────────────────

# 인증(MAPI-Key 검증 게이트)을 건너뛰고 앱을 바로 렌더할지 여부
REACT_APP_SKIP_AUTH=true

# 개발용 MAPI-Key. URL 의 ?mapiKey= 대신 API 요청에 사용됩니다.
# (비워두면 URL 쿼리스트링의 mapiKey 를 그대로 사용)
REACT_APP_MAPI_KEY=

# 개발용 Base URL — 프로그램 경로(civil/gen)까지 포함해야 합니다.
# 예: https://moa-engineers.midasit.com:443/civil
# (비워두면 VerifyUtil 이 MAPI-Key 검증 후 자동으로 결정)
REACT_APP_BASE_URL=
